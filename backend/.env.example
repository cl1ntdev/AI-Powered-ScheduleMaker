# Example .env for the FastAPI backend
# Copy this file to `.env` and fill in the real values before running the app/container.
#
# Secrets
GROQ_API_KEY=your_groq_api_key_here     # Required by services/ai.py (used to talk to Groq/OpenAI-compatible API)
OPENAI_API_KEY=your_openai_api_key_here # Optional, if you use official OpenAI endpoints elsewhere

# Server settings
HOST=0.0.0.0
PORT=8000

# Runtime / deployment
PYTHONUNBUFFERED=1
RELOAD=false            # set to true for local development (uvicorn --reload); leave false in production
GUNICORN_WORKERS=2      # used by the Dockerfile/entrypoint when running gunicorn

# Logging
LOG_LEVEL=info

# Optional: CORS / frontend URL (if you want to restrict allowed origins)
# Set to a comma-separated list (e.g. http://localhost:3000,http://example.com) or leave empty for '*'
CORS_ALLOWED_ORIGINS=

# Notes:
# - Keep this file out of version control once you add real secret values.
# - For docker-compose, the `.env` file in the backend folder will be loaded automatically by the compose configuration.
# - If you use a different secret name for the API key in production, update your deployment to set GROQ_API_KEY accordingly.
